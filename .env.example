# PostgreSQL Bağlantısı
DATABASE_URL=postgresql://postgres:changeme@localhost:5433/nutrilens

# JWT Güvenlik Anahtarı — üretmek için: python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=change-this-to-a-random-secret-key

# JWT Ayarları
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# AI Model Yolu
MODEL_PATH=model/food_model.pt

# Güven Eşiği (0.0 - 1.0)
CONFIDENCE_THRESHOLD=0.50

# Maksimum Görsel Boyutu (MB)
MAX_IMAGE_SIZE_MB=10
